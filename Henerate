function log(msg, cls='') {
  const el = document.getElementById('log');
  el.innerHTML += `<div class="${cls}">${msg}</div>`;
  el.scrollTop = el.scrollHeight;
}

async function fetchIcon(appId) {
  try {
    const r = await fetch(`https://itunes.apple.com/lookup?id=${appId}&country=fr`);
    const d = await r.json();
    if (d.results && d.results[0]) {
      return d.results[0].artworkUrl100 || d.results[0].artworkUrl60 || null;
    }
  } catch(e) {}
  try {
    const r = await fetch(`https://itunes.apple.com/lookup?id=${appId}&country=us`);
    const d = await r.json();
    if (d.results && d.results[0]) {
      return d.results[0].artworkUrl100 || null;
    }
  } catch(e) {}
  return null;
}

async function run() {
  const btn = document.getElementById('btn');
  btn.disabled = true;
  btn.textContent = '⏳ En cours...';
  
  log('🚀 Démarrage de la récupération des icônes...', 'info');
  log(`📋 ${GAMES.length} jeux à traiter`, 'info');
  log('─'.repeat(50));

  const icons = {};
  let ok = 0, fail = 0;
  
  for (const g of GAMES) {
    if (!g.i) { log(`⬜ ${g.n} — pas d'App ID`, 'err'); fail++; continue; }
    const url = await fetchIcon(g.i);
    if (url) {
      icons[g.i] = url;
      log(`✅ ${g.n}`, 'ok');
      ok++;
    } else {
      icons[g.i] = null;
      log(`❌ ${g.n} (id: ${g.i})`, 'err');
      fail++;
    }
    await new Promise(r => setTimeout(r, 150));
  }
  
  log('─'.repeat(50));
  log(`✅ ${ok} icônes récupérées · ❌ ${fail} échecs`, 'info');
  log('📦 Génération du fichier index.html final...', 'info');
  
  const html = generateHTML(icons);
  const blob = new Blob([html], {type:'text/html'});
  const url = URL.createObjectURL(blob);
  
  document.getElementById('dl').style.display = 'block';
  document.getElementById('dl').innerHTML = `
    <p style="color:#64ffda;font-size:14px;margin-bottom:12px;">✅ Fichier prêt ! Télécharge-le et remplace ton index.html sur GitHub.</p>
    <a href="${url}" download="index.html">⬇️ Télécharger index.html (avec icônes)</a>
  `;
  
  btn.textContent = '✅ Terminé !';
  log('🎉 Fini ! Télécharge le fichier et upload-le sur GitHub.', 'ok');
}

function svgAvatar(name) {
  const cols = [["#7c4dff","#311b92"],["#ff4d8f","#880e4f"],["#00d4aa","#004d40"],
                ["#448aff","#0d47a1"],["#ffca28","#e65100"],["#ea4335","#4e342e"]];
  const [c1,c2] = cols[name.charCodeAt(0)%cols.length];
  const l = (name.match(/\b\w/g)||[name[0]]).slice(0,2).join('').toUpperCase();
  return `data:image/svg+xml,${encodeURIComponent(
    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${c1}"/><stop offset="100%" stop-color="${c2}"/></linearGradient></defs><rect width="100" height="100" rx="22" fill="url(#g)"/><text x="50" y="64" font-family="Arial Black,sans-serif" font-size="38" font-weight="900" fill="white" text-anchor="middle">${l}</text></svg>`
  )}`;
}

function generateHTML(icons) {
