    return '<span class="bs bna">'+ic+' N/A</span>';
  }
  return '<div class="sr">'+btn(iosUrl(g.i),'🍎','App Store','bi')+btn(andUrl(g.a),'🤖','Play','ba')+'</div>';
}

function renderStrip(){
  const el=document.getElementById('strip');
  G.filter(g=>g.hot).forEach(g=>{
    const c=document.createElement('div');c.className='sc';
    c.innerHTML='<div class="sc-img"><img src="'+g.iconUrl+'" alt="'+g.n+'" loading="lazy"></div><div class="sc-name">'+g.n+'</div><div class="sc-date">'+g.d+' Mars</div>';
    c.addEventListener('click',()=>{const t=document.getElementById('day'+g.d);if(t)t.closest('.dg').scrollIntoView({behavior:'smooth',block:'start'});});
    el.appendChild(c);
  });
}

function renderList(){
  const list=document.getElementById('list');
  const grp={};
  G.forEach(g=>{if(!grp[g.d])grp[g.d]={w:g.w,items:[]};grp[g.d].items.push(g);});
  Object.keys(grp).sort().forEach(date=>{
    const{w,items}=grp[date];
    const sec=document.createElement('div');sec.className='dg';sec.id='day'+date;
    sec.innerHTML='<div class="dh"><div class="dt"><span class="dn">'+date+'</span><span class="dw">'+w+'</span></div><div class="dhr"></div><div class="dc">'+items.length+' sortie'+(items.length>1?'s':'')+'</div></div>';
    const grid=document.createElement('div');grid.className='gg';
    items.forEach(g=>{
      const card=document.createElement('div');card.className='gc'+(g.hot?' hot':'');
      if(g.hot) card.innerHTML='<div class="ribbon">⭐ Top</div>';
      const top=document.createElement('div');top.className='ct';
      top.innerHTML='<div class="ci"><img src="'+g.iconUrl+'" alt="'+g.n+'" loading="lazy"></div><div class="cinfo"><div class="cn">'+g.n+'</div><div class="ctags">'+g.t.map(t=>'<span class="tag">'+t+'</span>').join('')+'</div></div>';
      card.appendChild(top);
      card.insertAdjacentHTML('beforeend',storeRow(g));
      grid.appendChild(card);
    });
    sec.appendChild(grid);list.appendChild(sec);
  });
}

function initVisits(){
  const u=encodeURIComponent(location.href.split('?')[0]);
  fetch('https://hits.seeyoufarm.com/api/count/incr/badge.svg?url='+u+'&count_bg=%237C4DFF&title_bg=%231E1C2C&title=vues&edge_flat=true')
    .then(r=>r.text()).then(svg=>{
      const m=svg.match(/>(\d[\d,]*)</g);
      if(m&&m.length){document.getElementById('vc').textContent=m[m.length-1].replace(/[<>]/g,'').replace(/,/g,'');}
      else document.getElementById('vc').textContent='actif';
    }).catch(()=>{document.getElementById('vc').textContent='actif';});
}

renderStrip();renderList();initVisits();
<\/script>
